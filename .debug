<?xml version="1.0" encoding="UTF-8"?>
<ExtensionList>
    <!-- Ports for main UI panel -->
    <Extension Id="com.shuttle.v2.panel">
        <HostList>
            <Host Name="ILST" Port="8088"/>
            <Host Name="PHXS" Port="8089"/>
            <Host Name="PHSP" Port="8089"/>
        </HostList>
    </Extension>

    <!-- Ports for background hidden communication extension -->
    <Extension Id="com.shuttle.v2.hidden">
        <HostList>
            <Host Name="ILST" Port="8090"/>
            <Host Name="PHXS" Port="8091"/>
            <Host Name="PHSP" Port="8091"/>
        </HostList>
    </Extension>
</ExtensionList>
